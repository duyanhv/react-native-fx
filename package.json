{
  "name": "react-native-fx-monorepo",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages"
  ],
  "scripts": {
    "build": "cd packages && bun run build",
    "lint": "cd packages && bun run lint",
    "test": "cd packages && bun run test",
    "example": "bun --cwd example start",
    "example:ios": "bun --cwd example ios",
    "example:android": "bun --cwd example android"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
