{
  "name": "react-native-fx",
  "version": "0.1.0",
  "description": "Interactable native iOS Metal ShaderView for React Native",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "node internal/module_scripts/build.js",
    "clean": "node internal/module_scripts/clean.js",
    "lint": "eslint src/",
    "test": "node internal/module_scripts/test.js",
    "prepare": "node internal/module_scripts/prepare.js",
    "open:ios": "node internal/module_scripts/open-ios.js",
    "open:android": "node internal/module_scripts/open-android.js",
    "swift:format": "xcrun swift-format format --in-place --recursive ios",
    "swift:lint": "xcrun swift-format lint --recursive ios"
  },
  "keywords": [
    "react-native",
    "expo",
    "react-native-fx",
    "FxShader"
  ],
  "repository": "",
  "bugs": {
    "url": "/issues"
  },
  "author": "Duy Anh <meta-vn3@metainnotech.com> ()",
  "license": "MIT",
  "homepage": "#readme",
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/jest": "^29.2.1",
    "@types/react": "~19.2.16",
    "babel-preset-expo": "~56.0.14",
    "eslint": "~9.39.4",
    "eslint-config-universe": "^15.0.3",
    "expo": "~56.0.8",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.0",
    "prettier": "^3.0.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "roots": [
      "<rootDir>/src"
    ]
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
