{
  "name": "react-native-fx",
  "version": "0.1.0",
  "description": "A native presentation runtime for React Native — platform-native effects and motion, configured declaratively from JS.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "react-native": "./build/index.js",
      "default": "./build/index.js"
    }
  },
  "files": [
    "build",
    "ios",
    "android",
    "expo-module.config.json"
  ],
  "scripts": {
    "build": "node internal/module_scripts/build.js",
    "clean": "node internal/module_scripts/clean.js",
    "lint": "biome check .",
    "test": "node internal/module_scripts/test.js",
    "prepare": "node internal/module_scripts/prepare.js",
    "open:ios": "node internal/module_scripts/open-ios.js",
    "open:android": "node internal/module_scripts/open-android.js",
    "swift:format": "xcrun swift-format format --in-place --recursive ios",
    "swift:lint": "xcrun swift-format lint --recursive ios"
  },
  "keywords": [
    "react-native",
    "expo",
    "react-native-fx",
    "ios",
    "android",
    "effects",
    "animation",
    "metal",
    "agsl"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/duyanhv/react-native-fx.git",
    "directory": "packages"
  },
  "bugs": {
    "url": "https://github.com/duyanhv/react-native-fx/issues"
  },
  "author": "Duy Anh <meta-vn3@metainnotech.com>",
  "license": "MIT",
  "homepage": "https://github.com/duyanhv/react-native-fx#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@biomejs/biome": "^2.0.0",
    "@types/jest": "^29.2.1",
    "@types/react": "~19.2.16",
    "babel-preset-expo": "~56.0.14",
    "expo": "~56.0.8",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "roots": [
      "<rootDir>/src"
    ],
    "passWithNoTests": true
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
